<Footer />

<script>
// Aanvraagformulier → opent de mailclient met alles vooringevuld (geen backend nodig).
// Later live met een echt endpoint? Zet action/method op het <form> en vervang deze handler.
(() => {
  const form = document.getElementById('aanvraagForm');
  if (!form) return;
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form.reportValidity()) return;
    const v = (n) => (form.elements[n]?.value || '').trim();
    const body =
      `Naam: ${v('naam')}\n` +
      `Telefoon: ${v('telefoon') || '—'}\n` +
      `E-mail: ${v('email')}\n` +
      `Gelegenheid: ${v('gelegenheid')}\n` +
      `Aantal personen: ${v('aantal') || '—'}\n` +
      `Gewenste datum: ${v('datum') || '—'}\n\n` +
      `Bericht:\n${v('bericht') || '—'}\n`;
    const subject = `Aanvraag — ${v('gelegenheid')}${v('aantal') ? ' (' + v('aantal') + ' pers.)' : ''}`;
    window.location.href =
      `mailto:hallo@cafebrakke.nl?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  });
})();

// Hero-video lazy laden: de poster toont direct, de ~16MB video laadt pas ná de
// eerste render (window 'load'), zodat hij de laadtijd en LCP niet blokkeert.
(() => {
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduce) return;                       // bij reduced-motion: poster laten staan, geen video
  const start = () => {
    const v = document.querySelector('.hero-video-bg');
    if (!v) return;
    const sources = v.querySelectorAll('source[data-src]');
    if (!sources.length || sources[0].src) return;   // al geladen
    sources.forEach(s => { s.src = s.dataset.src; });
    v.load();
    v.play().catch(() => {});
  };
  if (document.readyState === 'complete') setTimeout(start, 200);
  else window.addEventListener('load', () => setTimeout(start, 200));
})();

(() => {
  const container = document.getElementById('zoomContainer');
  const heroTitle = document.getElementById('heroTitle');
  const boxCaption = document.getElementById('boxCaption');
  const veil = document.getElementById('veil');
  const houseNumber = document.getElementById('houseNumber');
  const postNav = document.getElementById('postNav');

  const slots = {
    rozengracht: document.querySelector('.slot.rozengracht'),
    burger: document.querySelector('.slot.burger'),
    ajax: document.querySelector('.slot.ajax'),
    borrel: document.querySelector('.slot.borrel'),
    terras: document.querySelector('.slot.terras'),
    vedett: document.querySelector('.slot.vedett'),
  };
  const labels = document.querySelectorAll('.slot .label');

  // Easing
  const easeInOutCubic = t => t < 0.5 ? 4*t*t*t : 1 - Math.pow(-2*t+2,3)/2;
  const easeOutQuart = t => 1 - Math.pow(1-t,4);

  // Respect prefers-reduced-motion — skip the scroll-driven animations entirely
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (prefersReducedMotion){
    boxCaption.style.opacity = 1;
    boxCaption.style.transform = 'translateY(0)';
    veil.style.opacity = 0;
    // Pause the hero background video — no autoplay if user prefers less motion
    const heroVideo = document.querySelector('.hero-video-bg');
    if (heroVideo){ heroVideo.pause(); heroVideo.removeAttribute('autoplay'); }
    return;
  }

  let ticking = false;
  let lastProgress = -1;

  function update(){
    const rect = container.getBoundingClientRect();
    const total = container.offsetHeight - window.innerHeight;
    let raw = Math.max(0, Math.min(1, -rect.top / total));
    if (Math.abs(raw - lastProgress) < 0.001) return;
    lastProgress = raw;

    const e = easeInOutCubic(raw);
    const eq = easeOutQuart(raw);

    // ---- IMAGE TRANSFORMS — zoom ends with ONLY Rozengracht 16 visible ----
    // Rozengracht (center) — scales up to fill the sticky stage
    const rozScale = 1 + e * 2.1;      // ends ~3.1x — fills full-width sticky
    const rozTy = e * 22;              // re-center toward stage middle
    slots.rozengracht.style.transform = `translate(0%, ${rozTy}%) scale(${rozScale})`;
    slots.rozengracht.style.zIndex = 5;

    // Other 5 images: scale + translate far off-stage, then fade to 0
    const burScale = 1 + e * 5;
    slots.burger.style.transform = `translate(${e * -85}%, ${e * 40}%) scale(${burScale})`;

    const ajxScale = 1 + e * 5;
    slots.ajax.style.transform = `translate(${e * 85}%, ${e * 40}%) scale(${ajxScale})`;

    const borScale = 1 + e * 6;
    slots.borrel.style.transform = `translate(${e * -120}%, ${e * -50}%) scale(${borScale})`;

    const terScale = 1 + e * 7;
    slots.terras.style.transform = `translate(0%, ${e * -110}%) scale(${terScale})`;

    const vedScale = 1 + e * 6;
    slots.vedett.style.transform = `translate(${e * 120}%, ${e * -50}%) scale(${vedScale})`;

    // ---- OTHER IMAGES FADE OUT at end (so only Rozengracht 16 remains) ----
    const fadeOthers = Math.max(0, 1 - Math.max(0, (raw - 0.7) / 0.18));
    ['burger','ajax','borrel','terras','vedett'].forEach(k => {
      slots[k].style.opacity = fadeOthers;
    });

    // ---- LABEL FADE ----
    const labelOp = Math.max(0, 1 - raw / 0.22);
    labels.forEach(l => l.style.opacity = labelOp);

    // ---- STAGE CAPTION FADE ----
    const titleOp = Math.max(0, 1 - raw / 0.25);
    heroTitle.style.opacity = titleOp;

    // ---- HOUSE NUMBER 16 — appears mid-zoom, fades before fullscreen ----
    if (raw > 0.32 && raw < 0.72){
      houseNumber.classList.add('show');
    } else {
      houseNumber.classList.remove('show');
    }

    // ---- ROZENGRACHT IMAGE FILTER — cinematic ramp ----
    const rozImg = slots.rozengracht.querySelector('img');
    if (rozImg){
      const sat = 0.88 + e * 0.20;      // .88 → 1.08
      const con = 1.05 + e * 0.10;      // 1.05 → 1.15
      const bright = 0.98 + e * 0.05;   // .98 → 1.03
      rozImg.style.filter = `saturate(${sat}) contrast(${con}) brightness(${bright})`;
    }

    // ---- VEIL + BOX CAPTION ----
    const overP = Math.max(0, (raw - 0.68) / 0.3);
    veil.style.opacity = overP;
    boxCaption.style.opacity = overP;
    boxCaption.style.transform = `translateY(${(1 - overP) * 20}px)`;

    // ---- POST-ZOOM NAV — show after zoom completes ----
    if (raw >= 0.95){
      postNav.classList.add('show');
    } else if (raw < 0.85){
      postNav.classList.remove('show');
    }
  }

  function tick(){
    if (!ticking){
      requestAnimationFrame(() => {
        update();
        ticking = false;
      });
      ticking = true;
    }
  }

  window.addEventListener('scroll', tick, {passive:true});
  window.addEventListener('resize', tick);
  update();

  // Reveal sections on scroll
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting){
        entry.target.style.opacity = 1;
        entry.target.style.transform = 'translateY(0)';
      }
    });
  }, {threshold: 0.12});

  document.querySelectorAll('.over-section, .section-2').forEach(s => {
    s.style.opacity = 0;
    s.style.transform = 'translateY(40px)';
    s.style.transition = 'opacity 1s cubic-bezier(.16,1,.3,1), transform 1s cubic-bezier(.16,1,.3,1)';
    revealObserver.observe(s);
  });

  // Mobile menu toggle
  const navToggle = document.getElementById('navToggle');
  const navMenu = document.getElementById('navMenu');
  if (navToggle && navMenu){
    navToggle.addEventListener('click', () => {
      const open = navMenu.classList.toggle('open');
      navToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      navToggle.setAttribute('aria-label', open ? 'Sluit menu' : 'Open menu');
    });
    navMenu.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        navMenu.classList.remove('open');
        navToggle.setAttribute('aria-expanded', 'false');
        navToggle.setAttribute('aria-label', 'Open menu');
      });
    });
  }
})();
</script>
</BaseLayout>
