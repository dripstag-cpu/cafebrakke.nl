---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import cb1 from '../assets/cb1-rozengracht.jpg';
import cb2 from '../assets/cb2-burger.jpg';
import cb3 from '../assets/cb3-ajax.jpg';
import cb4 from '../assets/cb4-bedrijfsborrel.jpg';
import cb5 from '../assets/cb5-terras.jpg';
import cb6 from '../assets/cb6-bar.jpg';
import '../styles/home.css';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": ["BarOrPub", "Restaurant"],
  "name": "Café Brakke",
  "description": "Bruin café aan de Rozengracht 16 in de Jordaan, Amsterdam. Bier van de tap, burgers en borrelhapjes, cocktails en Ajax op het scherm.",
  "url": "https://cafebrakke.nl/",
  "telephone": "+31203201657",
  "email": "hallo@cafebrakke.nl",
  "image": "https://cafebrakke.nl/assets/cb1-rozengracht.jpg",
  "priceRange": "€€",
  "servesCuisine": ["Bar food", "Burgers", "Ontbijt", "Cocktails"],
  "currenciesAccepted": "EUR",
  "paymentAccepted": "Pin, Contant, Creditcard",
  "acceptsReservations": "False",
  "hasMenu": "https://cafebrakke.nl/menu.html",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Rozengracht 16",
    "postalCode": "1016 NB",
    "addressLocality": "Amsterdam",
    "addressRegion": "Noord-Holland",
    "addressCountry": "NL"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 52.3738393,
    "longitude": 4.8799906
  },
  "hasMap": "https://www.google.com/maps/search/?api=1&query=Caf%C3%A9%20Brakke%20Rozengracht%2016%20Amsterdam",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Sunday"],
      "opens": "09:00",
      "closes": "01:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Friday", "Saturday"],
      "opens": "09:00",
      "closes": "03:00"
    }
  ],
  "areaServed": "Jordaan, Amsterdam",
  "publicAccess": true
};
---
<BaseLayout
  title="Café Brakke · Bruin café aan de Rozengracht in de Jordaan"
  description="Café Brakke — bruin café aan de Rozengracht 16 in de Jordaan, Amsterdam. Bier van de tap, burgers en borrelhapjes, cocktails, Ajax op het scherm en een terras op het zuiden. Loop binnen."
  canonical="https://cafebrakke.nl/"
  ogType="business.business"
  ogTitle="Café Brakke · Bruin café in de Jordaan"
  ogDescription="Bier van de tap, burgers, cocktails en Ajax op het scherm. Rozengracht 16, Amsterdam. Loop binnen voor één biertje — twee uur later ben je er nog."
  ogImage="https://cafebrakke.nl/assets/cb1-rozengracht.jpg"
  jsonLd={jsonLd}
>
  <Fragment slot="head">
    <link rel="preload" as="image" href="/assets/hero-poster.webp" type="image/webp" fetchpriority="high" />
  </Fragment>

<!-- ============ POST-ZOOM NAVIGATION ============ -->
<Nav />

<!-- ============ HERO INTRO ============ -->
<section class="hero-intro">
  <div class="hero-poster-bg" aria-hidden="true"></div>
  <video class="hero-video-bg" muted loop playsinline preload="none" poster="/assets/hero-poster.webp" aria-hidden="true">
    <source data-src="/assets/hero.webm" type="video/webm">
    <source data-src="/assets/hero.mp4" type="video/mp4">
  </video>
  <div class="hero-cinema-overlay" aria-hidden="true"></div>
  <div class="hero-intro-content">
    <span class="kicker">Bruin café · Jordaan</span>
    <h1>Café Brakke<span class="period">.</span></h1>
    <p class="tagline">Aan de <em>Rozengracht</em>. Voor een hapje of een drankje,<br>voetbal op het scherm of je team borrelen na het werk.</p>
    <div class="hero-cta-row">
      <a class="hero-cta primary" href="#kaart">Bekijk de kaart</a>
      <a class="hero-cta" href="#borrels">Naar bedrijfsborrels</a>
      <a class="hero-cta" href="#voetbal">Voetbal kijken</a>
    </div>
    <div class="scroll-cue">
      <span class="arrow">↓</span>
    </div>
  </div>
</section>

<!-- ============ ZOOM CONTAINER — BOXED ============ -->
<div class="zoom-wrap">
<section class="zoom-container" id="zoomContainer">
  <div class="zoom-sticky">

    <!-- Subtle stage caption (replaces overlay-heavy title) -->
    <div class="stage-caption" id="heroTitle" aria-hidden="true" style="display:none"></div>

    <!-- 6 image slots — start as editorial grid -->
    <div class="image-stage">
      <a class="slot rozengracht" href="#locatie" data-key="rozengracht" aria-label="Café Brakke aan de Rozengracht 16, Jordaan">
        <div class="frame">
          <Image src={cb1} alt="Tafel in Café Brakke met koffie, notitieboek en zonlicht — Rozengracht 16, Jordaan" widths={[768, 1200, 1584]} sizes="100vw" loading="eager" fetchpriority="high" />
        </div>
        <span class="label"><span class="index">01</span>Rozengracht 16</span>
      </a>
      <a class="slot burger" href="/menu.html" data-key="burger" aria-label="De Brakke Burger op de kaart">
        <div class="frame">
          <Image src={cb2} alt="Brakke Burger op tafel" widths={[240, 400, 640]} sizes="(max-width: 768px) 40vw, 320px" loading="eager" />
        </div>
        <span class="label"><span class="index">02</span>Brakke Burger</span>
      </a>
      <a class="slot ajax" href="#voetbal" data-key="ajax" aria-label="Ajax kijken bij Café Brakke">
        <div class="frame">
          <Image src={cb3} alt="Wedstrijd op het scherm bij Café Brakke" widths={[240, 400, 640]} sizes="(max-width: 768px) 40vw, 320px" loading="eager" />
        </div>
        <span class="label"><span class="index">03</span>Voetbal staat aan</span>
      </a>
      <a class="slot borrel" href="#borrels" data-key="borrel" aria-label="Bedrijfsborrel bij Café Brakke">
        <div class="frame">
          <Image src={cb4} alt="Bedrijfsborrel met collega's" widths={[240, 400, 640]} sizes="(max-width: 768px) 40vw, 320px" loading="eager" />
        </div>
        <span class="label"><span class="index">04</span>Bedrijfsborrel</span>
      </a>
      <a class="slot terras" href="#locatie" data-key="terras" aria-label="Terras van Café Brakke">
        <div class="frame">
          <Image src={cb5} alt="Terras op de Rozengracht in de zon" widths={[240, 400, 640]} sizes="(max-width: 768px) 40vw, 320px" loading="eager" />
        </div>
        <span class="label"><span class="index">05</span>Terras</span>
      </a>
      <a class="slot vedett" href="/menu.html" data-key="vedett" aria-label="Drankenkaart Café Brakke">
        <div class="frame">
          <Image src={cb6} alt="Vedett op de tap" widths={[240, 400, 640]} sizes="(max-width: 768px) 40vw, 320px" loading="eager" />
        </div>
        <span class="label"><span class="index">06</span>Aan de bar</span>
      </a>
    </div>

    <!-- Decorative house number (appears mid-zoom) -->
    <div class="house-number" id="houseNumber">16</div>

    <!-- Soft veil at zoom-end -->
    <div class="veil" id="veil"></div>

    <!-- Caption on the final fullscreen Rozengracht image -->
    <div class="box-caption" id="boxCaption">
      <span class="tag">№ 16 · Rozengracht</span>
      <h3>Bruin café.<br><em>Op de Rozengracht</em>.</h3>
    </div>

  </div>
</section>
</div>

<!-- ============ OVER ONS · Achter de bar + reviews ============ -->
<section class="section-2" id="over">
  <div class="pullquote-block">
    <div class="left">
      <div class="label">Over ons · Achter de bar</div>
      <div class="pullquote">
        Albart runt Brakke.<span class="lift">Hij onthoudt je naam na drie bezoeken. <em>Niet omdat het moet</em>, omdat dat hier zo werkt.</span>
      </div>
    </div>
    <div class="right">
      <p>Bij Brakke staat geen 17e-eeuws verhaal op de gevel. Wel een bar waar Albart meestal zelf staat: overdag, 's avonds laat, ook op zondag. Geen service-protocol, geen kelner-script.</p>
      <p>Het team eromheen wisselt. Reviewers noemen door de jaren namen. <strong>Samuel</strong>, <strong>Percy</strong>, <strong>Mario</strong>, <strong>Ella</strong>. Iedereen die er staat staat er voor de gasten.</p>
      <p>Dat is misschien wel het enige dat we wél bij ons houden.</p>
    </div>
  </div>
  <div class="roster">
    <span class="label">In het boek</span>
    <span class="name">Albart</span><span class="sep">·</span>
    <span class="name">Samuel</span><span class="sep">·</span>
    <span class="name">Percy</span><span class="sep">·</span>
    <span class="name">Mario</span><span class="sep">·</span>
    <span class="name">Ella</span><span class="sep">·</span>
    <span class="name">Francesca</span>
  </div>
</section>

<!-- ============ REVIEWS ============ -->
<section class="reviews-section">
  <div class="reviews-inner">
    <div class="reviews-head">
      <span class="kicker">Wat gasten zeggen</span>
      <h3>4,7 op <em>Tripadvisor</em>.<br>4,6 op <em>Google</em>.</h3>
      <p class="strap">Niet ons verhaal. Hun woorden.</p>
    </div>
    <div class="reviews-grid">
      <figure class="review">
        <blockquote>"Lekker gezellig Amsterdams stamkroegje met uiterst vriendelijk personeel. En zoals het hoort in Amsterdam worden de wedstrijden van Ajax uitgezonden."</blockquote>
        <figcaption><span class="name">Jan</span><span class="meta">TripAdvisor</span></figcaption>
      </figure>
      <figure class="review">
        <blockquote>"Very homey feel where you're always family."</blockquote>
        <figcaption><span class="name">Manuel C</span><span class="meta">TripAdvisor</span></figcaption>
      </figure>
      <figure class="review">
        <blockquote>"De lekkerste clubsandwich die ik tot nu toe in mijn leven heb gegeten."</blockquote>
        <figcaption><span class="name">Elisabeth P</span><span class="meta">TripAdvisor</span></figcaption>
      </figure>
      <figure class="review">
        <blockquote>"The best burger in Amsterdam, it tastes homemade, and the wings were amazing."</blockquote>
        <figcaption><span class="name">Raya Dark</span><span class="meta">Google</span></figcaption>
      </figure>
      <figure class="review">
        <blockquote>"Tastiest pints and best music in Amsterdam. Friendliest and quickest barman in the Dam."</blockquote>
        <figcaption><span class="name">Padraig K</span><span class="meta">TripAdvisor</span></figcaption>
      </figure>
      <figure class="review">
        <blockquote>"Een echt Amsterdams café waar het personeel je bijna behandelt als een familielid."</blockquote>
        <figcaption><span class="name">Youri T</span><span class="meta">TripAdvisor</span></figcaption>
      </figure>
    </div>
    <div class="reviews-cta">
      <a href="https://www.google.com/maps/search/?api=1&amp;query=Caf%C3%A9%20Brakke%20Rozengracht%2016%20Amsterdam" target="_blank" rel="noopener" class="cta">Lees alle reviews</a>
    </div>
  </div>
</section>

<!-- ============ HAPJE & DRANKJE (kaart preview) ============ -->
<section class="over-section" id="kaart">
  <div class="kaart-block">
    <div class="kaart-head">
      <span class="kicker">Kaart</span>
      <h3>De Brakke Burger.<br><em>En al het andere</em>.</h3>
      <p class="strap">Bier op tap. Hapjes erbij. Plek voor een gesprek.</p>
    </div>
    <div class="kaart-cols">
      <div class="kaart-col">
        <h4>Uit de keuken</h4>
        <ul class="kaart-list">
          <li><span>The Classic Drip burger</span><span class="dots"></span><span>€ 13,90</span></li>
          <li><span>Brakke's Signature Combo</span><span class="dots"></span><span>€ 18,50</span></li>
          <li><span>Spareribs (incl. friet &amp; salade)</span><span class="dots"></span><span>€ 20,90</span></li>
          <li><span>Fish &amp; Chips</span><span class="dots"></span><span>€ 19,90</span></li>
          <li><span>Brakke Wings (12 st.)</span><span class="dots"></span><span>€ 18,50</span></li>
          <li><span>Bitterballen (6 st.)</span><span class="dots"></span><span>€ 7,50</span></li>
        </ul>
      </div>
      <div class="kaart-col">
        <h4>Aan de bar</h4>
        <ul class="kaart-list">
          <li><span>Amstel van de tap (vaasje)</span><span class="dots"></span><span>€ 4,00</span></li>
          <li><span>La Chouffe</span><span class="dots"></span><span>€ 6,75</span></li>
          <li><span>'t IJ — IJwit</span><span class="dots"></span><span>€ 6,75</span></li>
          <li><span>Huiswijn (glas)</span><span class="dots"></span><span>€ 5,75</span></li>
          <li><span>Espresso Martini</span><span class="dots"></span><span>€ 14,50</span></li>
          <li><span>Espresso</span><span class="dots"></span><span>€ 3,25</span></li>
        </ul>
      </div>
    </div>
    <p class="kaart-foot">Een greep uit de kaart. Ontbijt, burgers, gerechten, cocktails en dranken — de hele lijst staat op de menupagina. Pin, contant en creditcards. Allemaal goed.</p>
    <div class="kaart-cta-row">
      <a class="cta" href="/menu.html">Bekijk de volledige kaart</a>
    </div>
  </div>
</section>

<!-- ============ BORRELS & BEDRIJFSBORRELS ============ -->
<section class="borrels-section" id="borrels">
  <div class="borrels-inner">
    <div class="borrels-head">
      <span class="kicker">Borrels &amp; bedrijfsborrels</span>
      <h3>Met je team<br><em>na het werk</em>.</h3>
      <p class="strap">Voor tien tot vijfenveertig. Geen vergaderzaal-energie.</p>
    </div>
    <div class="borrels-cards">
      <article class="borrel-card">
        <div class="borrel-card-head">
          <span class="num">A</span>
          <h4>Onbeperkt drankarrangement</h4>
        </div>
        <p class="price">vanaf <strong>€ 27,50</strong> p.p.<br>voor 2 uur</p>
        <p>Bier, wijn, fris, koffie. Wij houden bij, jij hoeft niet te tellen.</p>
        <ul class="extras">
          <li>Bittergarnituur · + € 8,50 p.p.</li>
          <li>Borrelplank · + € 12,50 p.p.</li>
          <li>Uitgebreide borrelplank · + € 17,50 p.p.</li>
        </ul>
      </article>
      <article class="borrel-card">
        <div class="borrel-card-head">
          <span class="num">B</span>
          <h4>Rekening achteraf</h4>
        </div>
        <p class="price"><strong>Vrij bestellen</strong><br>één bon, één tekent</p>
        <p>Geen arrangement vooraf. Iedereen bestelt wat hij wil, één rekening op het kantoor.</p>
        <ul class="extras">
          <li>Factuur op kantoor-adres</li>
          <li>BTW-specificatie</li>
          <li>Geen aanbetaling tot 30 personen</li>
        </ul>
      </article>
    </div>
    <div class="borrels-foot">
      <p>Mailtje terug binnen één werkdag. Geen offerte-loop.</p>
      <div class="borrels-cta-row">
        <a class="cta primary" href="#reserveren">Stuur een aanvraag</a>
        <a class="cta" href="tel:+31203201657">Bel 020 320 1657</a>
      </div>
    </div>
  </div>
</section>

<!-- ============ AJAX & WEDSTRIJDEN ============ -->
<section class="voetbal-section" id="voetbal">
  <div class="voetbal-inner">
    <div class="voetbal-head">
      <span class="kicker">Ajax &amp; wedstrijden</span>
      <h3>Een bruin café<br><em>met de wedstrijd aan</em>.</h3>
      <p class="strap">Voor Ajax, voor de Klassieker, voor een Champions League-avond met je team.</p>
    </div>
    <div class="voetbal-grid">
      <div class="voetbal-text">
        <p>Bij Brakke staat de wedstrijd aan. Eredivisie standaard, ook de uitwedstrijden. De Klassieker altijd. Champions League-avonden vrijwel altijd. Op twee, soms drie schermen, met zichtlijn vanuit de bar.</p>
        <p>Het blijft een bruin café. Wie aan de bar zit voor een biertje, doet dat. Wie kijkt, kijkt mee. Bij een goal mag het iets harder.</p>
      </div>
      <div class="voetbal-agenda">
        <h4>Wat we uitzenden</h4>
        <ul>
          <li><span class="match">Eredivisie · thuis en uit</span><span class="time">Standaard</span></li>
          <li><span class="match">De Klassieker</span><span class="time">Altijd</span></li>
          <li><span class="match">Champions League · avonden</span><span class="time">Vrijwel altijd</span></li>
          <li><span class="match">CL knock-outs</span><span class="time">Druk, bel even</span></li>
          <li><span class="match">KNVB-beker · latere rondes</span><span class="time">Op aanvraag</span></li>
          <li><span class="match">Premier League, NBA, darts</span><span class="time">Wisselend</span></li>
        </ul>
        <p class="agenda-meta">Voor een specifieke wedstrijd: bel even, dan checken we het voor je.</p>
      </div>
    </div>
    <div class="voetbal-cta-row">
      <a class="cta primary" href="#reserveren">Plek voor je team</a>
      <a class="cta" href="tel:+31203201657">Bel voor de Klassieker</a>
    </div>
  </div>
</section>

<!-- ============ OVER ONS · Het pand ============ -->
<section class="over-section" id="locatie">
  <div class="section-3">
    <div class="map-block">
      <div class="figure">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2705.516282983623!2d4.879990579682747!3d52.37383926802996!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47c609db35f5711f%3A0xd75fabb47ff25c4f!2sCaf%C3%A9%20Brakke!5e0!3m2!1sen!2snl!4v1780309135961!5m2!1sen!2snl"
          width="100%"
          height="100%"
          style="border:0;position:absolute;inset:0;width:100%;height:100%;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Locatie Café Brakke op de kaart"></iframe>
      </div>
    </div>
    <div class="text-block">
      <span class="kicker">Op de Rozengracht</span>
      <h3>De straat-zijde van<br>de <em>Jordaan</em>.</h3>
      <p>Rozengracht 16, in de Jordaan. Drie minuten van de Westermarkt, vijf van het Anne Frank Huis. De Rozengracht is de gedempte hoofdader die de Jordaan oost-west doorsnijdt. De straat-zijde, niet de gracht-zijde.</p>
      <p>Het terras op het zuiden vangt zon vanaf het voorjaar.</p>
      <div class="facts">
        <div class="row"><span class="key">Adres</span>Rozengracht 16</div>
        <div class="row"><span class="key">Postcode</span>1016 NB</div>
        <div class="row"><span class="key">Tram</span>13, 17 · Westermarkt</div>
        <div class="row"><span class="key">Buurt</span>Jordaan</div>
      </div>
    </div>
  </div>
</section>

<!-- ============ AANVRAAG / RESERVEREN ============ -->

<section class="aanvraag-section" id="reserveren">
  <div class="aanvraag-inner">
    <div class="aanvraag-head">
      <span class="kicker">Aanvraag &amp; groepen</span>
      <h3>Met een groep<br><em>langskomen</em>?</h3>
      <p class="strap">Voor een gewone avond hoef je niks te regelen — loop binnen. Plan je een borrel, verjaardag of bedrijfsuitje vanaf zo'n tien personen? Stuur een aanvraag, dan houden we plek vrij.</p>
    </div>
    <div class="aanvraag-grid">
      <form class="aanvraag-form" id="aanvraagForm" novalidate>
        <div class="field-row">
          <div class="field">
            <label for="f-naam">Naam</label>
            <input id="f-naam" name="naam" type="text" autocomplete="name" required>
          </div>
          <div class="field">
            <label for="f-tel">Telefoon</label>
            <input id="f-tel" name="telefoon" type="tel" autocomplete="tel">
          </div>
        </div>
        <div class="field">
          <label for="f-mail">E-mail</label>
          <input id="f-mail" name="email" type="email" autocomplete="email" required>
        </div>
        <div class="field-row">
          <div class="field">
            <label for="f-type">Wat voor gelegenheid</label>
            <select id="f-type" name="gelegenheid">
              <option>Borrel met vrienden</option>
              <option>Bedrijfsborrel</option>
              <option>Verjaardag / feest</option>
              <option>Voetbalavond met groep</option>
              <option>Anders</option>
            </select>
          </div>
          <div class="field">
            <label for="f-aantal">Aantal personen</label>
            <input id="f-aantal" name="aantal" type="number" min="2" inputmode="numeric" placeholder="bijv. 15">
          </div>
        </div>
        <div class="field">
          <label for="f-datum">Gewenste datum</label>
          <input id="f-datum" name="datum" type="date">
        </div>
        <div class="field">
          <label for="f-bericht">Bericht</label>
          <textarea id="f-bericht" name="bericht" placeholder="Vertel kort wat je zoekt — tijd, drankarrangement, hapjes erbij…"></textarea>
        </div>
        <button class="form-submit" type="submit">Stuur de aanvraag</button>
        <p class="form-note">We mailen terug binnen één werkdag. Geen offerte-loop.</p>
      </form>
      <aside class="aanvraag-aside">
        <h4>Liever direct?</h4>
        <p>Bellen mag altijd — vaak is dat het snelst, zeker voor een datum binnenkort of een drukke voetbalavond.</p>
        <p>Tot 30 personen vragen we geen aanbetaling. Factuur op kantooradres met btw-specificatie kan.</p>
        <div class="direct">
          <a href="tel:+31203201657">020 320 1657</a><br>
          <a href="mailto:hallo@cafebrakke.nl">hallo@cafebrakke.nl</a><br>
          Rozengracht 16, Jordaan
        </div>
      </aside>
    </div>
  </div>
</section>


<!-- ============ CTA ============ -->
<section class="cta-section">
  <span class="kicker">Welkom</span>
  <h2>Loop binnen voor één biertje.<br><em>Twee uur later ben je er nog.</em></h2>
  <div class="cta-row">
    <a class="cta primary" href="/menu.html">Bekijk de kaart</a>
    <a class="cta" href="#reserveren">Naar bedrijfsborrels</a>
    <a class="cta" href="#voetbal">Ajax kijken</a>
  </div>
</section>

