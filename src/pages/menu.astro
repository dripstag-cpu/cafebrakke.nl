---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/menu.css';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://cafebrakke.nl/" },
    { "@type": "ListItem", "position": 2, "name": "De kaart", "item": "https://cafebrakke.nl/menu.html" }
  ]
};
---
<BaseLayout
  title="De kaart · Café Brakke — ontbijt, burgers, cocktails & dranken"
  description="De volledige kaart van Café Brakke aan de Rozengracht 16 in de Jordaan: ontbijt, lunch, burgers, gerechten, borrelhapjes, cocktails, bier, wijn en koffie."
  canonical="https://cafebrakke.nl/menu.html"
  ogType="restaurant.menu"
  ogTitle="De kaart · Café Brakke"
  ogDescription="Ontbijt, burgers, cocktails en dranken — de volledige kaart van Café Brakke in de Jordaan."
  ogImage="https://cafebrakke.nl/assets/cb2-burger.jpg"
  jsonLd={jsonLd}
>
<header class="topbar">
  <a class="back" href="/">Terug</a>
  <a class="brand" href="/">Café Brakke<span>.</span></a>
  <a class="back" style="text-transform:none;letter-spacing:.04em" href="tel:+31203201657">020 320 1657</a>
</header>

<section class="menu-hero">
  <span class="kicker">Rozengracht 16 · Jordaan</span>
  <h1>De <em>kaart</em>.</h1>
  <p>Van ontbijt tot de laatste cocktail. Keuken open, tap open, koffie altijd.</p>
</section>

<nav class="cat-nav" aria-label="Menu-categorieën">
  <div class="cat-nav-inner">
    <a href="#ontbijt">Ontbijt</a>
    <a href="#lunch">Lunch</a>
    <a href="#burgers">Burgers</a>
    <a href="#gerechten">Gerechten</a>
    <a href="#snacks">Snacks &amp; Wings</a>
    <a href="#cocktails">Cocktails</a>
    <a href="#bier">Bier &amp; Wijn</a>
    <a href="#sterk">Sterke drank</a>
    <a href="#koffie">Koffie &amp; Warm</a>
    <a href="#fris">Fris</a>
  </div>
</nav>

<main>

  <!-- ============ ONTBIJT ============ -->
  <section class="cat" id="ontbijt">
    <h2 class="cat-title">Ontbijt &amp; <em>eieren</em></h2>
    <p class="cat-note">Tot in de middag · all day breakfast</p>
    <div class="groups-2">
      <div class="group">
        <h3>Croissants</h3>
        <div class="item"><div class="item-row"><span class="item-name">Croissant Naturel</span><span class="item-price">6,50</span></div><p class="item-desc">Met jam, honing en boter.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Croissant Kaas</span><span class="item-price">7,90</span></div><p class="item-desc">Botercroissant met kaas.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Croissant Ham &amp; Kaas</span><span class="item-price">9,90</span></div><p class="item-desc">Warm, met gesmolten kaas.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Croissant Zalm</span><span class="item-price">9,90</span></div><p class="item-desc">Gerookte zalm, roomkaas en dille.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Croissant Nutella</span><span class="item-price">9,90</span></div><p class="item-desc">Gevuld met romige Nutella.</p></div>
      </div>
      <div class="group">
        <h3>Pannenkoeken — zoet</h3>
        <div class="item"><div class="item-row"><span class="item-name">Classic</span><span class="item-price">9,90</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Nutella</span><span class="item-price">11,90</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Banaan</span><span class="item-price">12,50</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Kaneel</span><span class="item-price">12,50</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Appel &amp; honing</span><span class="item-price">12,50</span></div></div>
      </div>
      <div class="group">
        <h3>Pannenkoeken — hartig</h3>
        <div class="item"><div class="item-row"><span class="item-name">Kaas</span><span class="item-price">10,90</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Ham &amp; kaas</span><span class="item-price">12,50</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Bacon &amp; kaas</span><span class="item-price">12,50</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Ham, kaas &amp; ei</span><span class="item-price">13,50</span></div></div>
      </div>
      <div class="group">
        <h3>Wentelteefjes</h3>
        <div class="item"><div class="item-row"><span class="item-name">Classic French Toast</span><span class="item-price">9,90</span></div><p class="item-desc">Licht bestoven met poedersuiker.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Nutella French Toast</span><span class="item-price">11,90</span></div><p class="item-desc">Gevuld met warme Nutella.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Banaan-karamel French Toast</span><span class="item-price">12,90</span></div><p class="item-desc">Banaan met karameldrizzle.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Kaneel French Toast</span><span class="item-price">10,90</span></div><p class="item-desc">Met kaneelsuiker.</p></div>
      </div>
      <div class="group">
        <h3>Omeletten</h3>
        <div class="item"><div class="item-row"><span class="item-name">Classic</span><span class="item-price">10,90</span></div><p class="item-desc">Simpel en luchtig.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Kaas</span><span class="item-price">11,90</span></div><p class="item-desc">Gesmolten cheddar of Gouda.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Veggie</span><span class="item-price">12,90</span></div><p class="item-desc">Paprika, ui en champignons.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Ham &amp; kaas</span><span class="item-price">12,90</span></div><p class="item-desc">Gerookte ham en kaas.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Mediterraan</span><span class="item-price">14,90</span></div><p class="item-desc">Feta, spinazie, olijven en tomaat.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Zalm</span><span class="item-price">14,90</span></div><p class="item-desc">Luchtig ei met gerookte zalm.</p></div>
      </div>
      <div class="group">
        <h3>Ontbijtschotels</h3>
        <div class="item"><div class="item-row"><span class="item-name">Classic English Breakfast</span><span class="item-price">10,90</span></div><p class="item-desc">Toast, eieren, bacon, tomaat.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Full English Breakfast</span><span class="item-price">14,90</span></div><p class="item-desc">Toast, eieren, bacon, tomaat, bonen, champignons en worst.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Continental Breakfast</span><span class="item-price">10,90</span></div><p class="item-desc">Toast, ham, kaas, honing, jam en boter.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Veggie English Breakfast</span><span class="item-price">12,90</span></div><p class="item-desc">Toast, eieren, gegrilde groenten en bonen.</p></div>
      </div>
    </div>
  </section>

  <!-- ============ LUNCH ============ -->
  <section class="cat" id="lunch">
    <h2 class="cat-title">Lunch &amp; <em>salades</em></h2>
    <p class="cat-note">Panini · salades</p>
    <div class="groups-2">
      <div class="group">
        <h3>Panini</h3>
        <div class="item"><div class="item-row"><span class="item-name">Caprese</span><span class="item-price">9,50</span></div><p class="item-desc">Gesmolten mozzarella, tomaat en basilicumpesto.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Ham &amp; kaas</span><span class="item-price">9,50</span></div><p class="item-desc">Gerookte ham en gesmolten cheddar.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Chicken Pesto</span><span class="item-price">12,50</span></div><p class="item-desc">Gegrilde kip, pesto en mozzarella.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Tuna Melt</span><span class="item-price">11,50</span></div><p class="item-desc">Tonijnsalade met gesmolten kaas.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Veggie</span><span class="item-price">11,50</span></div><p class="item-desc">Gegrilde paprika, ui, courgette en mozzarella.</p></div>
      </div>
      <div class="group">
        <h3>Salades</h3>
        <div class="item"><div class="item-row"><span class="item-name">Mix Salad</span><span class="item-price">5,75</span></div><p class="item-desc">Gemengde sla met tomaat en komkommer, lichte huisdressing.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Caesar Salad</span><span class="item-price">10,90</span></div><p class="item-desc">Romaine, croutons en parmezaan in klassieke caesardressing.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Caesar Chicken Salad</span><span class="item-price">13,90</span></div><p class="item-desc">Gegrilde kipfilet op romaine met croutons en parmezaan.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Greek Salad</span><span class="item-price">10,90</span></div><p class="item-desc">Sla, tomaat, komkommer, rode ui, olijven en feta.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Chicken Avocado Salad</span><span class="item-price">15,50</span></div><p class="item-desc">Gegrilde kip, avocado, pijnboompitten en parmezaan.</p></div>
      </div>
    </div>
  </section>

  <!-- ============ BURGERS ============ -->
  <section class="cat" id="burgers">
    <h2 class="cat-title">Burgers</h2>
    <p class="cat-note">Double smashed Irish beef, tenzij anders vermeld</p>
    <div class="groups-2">
      <div class="group">
        <div class="item"><div class="item-row"><span class="item-name">The Classic Drip</span><span class="item-price">13,90</span></div><p class="item-desc">Dubbele smashed beef, cheddar, augurk, ui, ketchup, mosterd.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">BBQ Bacon Burger</span><span class="item-price">15,90</span></div><p class="item-desc">Smashed beef, cheddar, smoky bacon, BBQ-saus, uienring.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Mushroom Swiss Burger</span><span class="item-price">16,90</span></div><p class="item-desc">Smashed beef, Zwitserse kaas, gebakken champignons, knoflookmayo.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Spicy Jalapeño Burger</span><span class="item-price">14,90</span></div><p class="item-desc">Smashed beef, cheddar, jalapeños, pittige mayo.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">The Truffle Philly</span><span class="item-price">17,50</span></div><p class="item-desc">Gegrilde steak, cheddar, ui, truffelmayo.</p></div>
      </div>
      <div class="group">
        <div class="item"><div class="item-row"><span class="item-name">The Crispy Thigh</span><span class="item-price">13,90</span></div><p class="item-desc">Buttermilk fried chicken thigh, slaw, augurk, pittige mayo.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Korean Fried Chicken Burger</span><span class="item-price">13,90</span></div><p class="item-desc">Krokante kip, gochujang-glaze, sesam.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">The Grilled Thigh</span><span class="item-price">13,90</span></div><p class="item-desc">Gegrilde chicken thigh, slaw, augurk, knoflookmayo.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Brakke's Signature Combo</span><span class="item-price">18,50</span></div><p class="item-desc">Irish beef + fried chicken, cheddar, sla, truffelmayo, drip sauce.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">The Beyond Dream <em>(vegan)</em></span><span class="item-price">13,90</span></div><p class="item-desc">Vegan patty, vegan kaas, sla, tomaat, augurk, krokante ui.</p></div>
      </div>
    </div>
  </section>

  <!-- ============ GERECHTEN ============ -->
  <section class="cat" id="gerechten">
    <h2 class="cat-title">Gerechten</h2>
    <p class="cat-note">Inclusief friet en salade</p>
    <div class="groups-2">
      <div class="group">
        <div class="item"><div class="item-row"><span class="item-name">Fish &amp; Chips</span><span class="item-price">19,90</span></div><p class="item-desc">Witvis in huisgemaakt bierbeslag, friet, coleslaw en huisgemaakte citroen-tartaar.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Kipsaté van de dij</span><span class="item-price">19,50</span></div><p class="item-desc">Gegrilde chicken thigh, romige pindasaus, friet en frisse salade.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Gegrilde chicken thigh</span><span class="item-price">18,50</span></div><p class="item-desc">Gemarineerd met kruiden, friet en frisse salade.</p></div>
      </div>
      <div class="group">
        <div class="item"><div class="item-row"><span class="item-name">Spareribs</span><span class="item-price">20,90</span></div><p class="item-desc">Langzaam gegaard, geglazuurd met huisgemaakte BBQ-saus, friet en salade.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Steak</span><span class="item-price">23,90</span></div><p class="item-desc">Gegrilde steak, romige champignonsaus, friet en frisse salade.</p></div>
      </div>
    </div>
  </section>

  <!-- ============ SNACKS & WINGS ============ -->
  <section class="cat" id="snacks">
    <h2 class="cat-title">Snacks, dirty fries &amp; <em>wings</em></h2>
    <p class="cat-note">Voor bij de borrel · om te delen</p>
    <div class="groups-2">
      <div class="group">
        <h3>Sides</h3>
        <div class="item"><div class="item-row"><span class="item-name">Huisgemaakte friet</span><span class="item-price">5,25</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Mozzarella sticks</span><span class="item-price">7,90</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Huisgemaakte uienringen</span><span class="item-price">8,90</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Nachos</span><span class="item-price">10,90</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Loaded Nachos + pulled chicken of beef</span><span class="item-price">14,90</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Bitterballen (6 st.)</span><span class="item-price">7,50</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Jalapeño Poppers</span><span class="item-price">8,90</span></div><p class="item-desc">Gevuld met kaas, pittig.</p></div>
      </div>
      <div class="group">
        <h3>Dirty Fries</h3>
        <div class="item"><div class="item-row"><span class="item-name">Sticky Cheese Jalapeño</span><span class="item-price">9,90</span></div><p class="item-desc">Friet, cheddarsaus, jalapeños, gebakken ui.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Truffle Parmesan Fries</span><span class="item-price">9,90</span></div><p class="item-desc">Friet, truffelmayo, parmezaan.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Smash Fries</span><span class="item-price">14,90</span></div><p class="item-desc">Friet met smashed beef, cheddar, augurk, ui, drip sauce.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Chili Cheese Fries</span><span class="item-price">14,90</span></div><p class="item-desc">Friet met chili beef, cheddarsaus, zure room.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Pulled Chicken Fries</span><span class="item-price">14,90</span></div><p class="item-desc">Friet, pulled chicken, BBQ-saus, kaas.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Buffalo Fries</span><span class="item-price">14,90</span></div><p class="item-desc">Friet met buffalo chicken en blauwe kaas.</p></div>
      </div>
      <div class="group">
        <h3>Streetfood &amp; bites</h3>
        <div class="item"><div class="item-row"><span class="item-name">Smashed Beef Taco's</span><span class="item-price">14,90</span></div><p class="item-desc">Tortilla's met smashed beef, cheddar, sla, tomaat, huissaus.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Mixed Dutch Snacks</span><span class="item-price">16,90</span></div><p class="item-desc">Klassieke Hollandse snacks om te delen, met sauzen.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Chicken Quesadillas</span><span class="item-price">15,90</span></div><p class="item-desc">Gegrilde kip en kaas in krokante tortilla, met sla, tomaat, huissaus.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Chicken Tenders</span><span class="item-price">8,90</span></div><p class="item-desc">Huisgemaakt van chicken thigh, goudbruin gefrituurd, met dipsaus.</p></div>
      </div>
      <div class="group">
        <h3>Homemade Wings <span class="price-cols">6 / 12 / 18 st.</span></h3>
        <div class="item"><div class="item-row"><span class="item-name">Brakke Wings</span><span class="item-price"><span class="multi">10,50</span> <span class="multi">18,50</span> <span class="multi">26,50</span></span></div><p class="item-desc">Sticky soja-knoflook glaze, sesam.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Hot Brakke Wings</span><span class="item-price"><span class="multi">10,50</span> <span class="multi">18,50</span> <span class="multi">26,50</span></span></div><p class="item-desc">Pittige chiliglaze, rode peper.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Sweet BBQ Wings</span><span class="item-price"><span class="multi">10,50</span> <span class="multi">18,50</span> <span class="multi">26,50</span></span></div><p class="item-desc">Smoky honing-BBQ.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Buffalo Wings</span><span class="item-price"><span class="multi">10,50</span> <span class="multi">18,50</span> <span class="multi">26,50</span></span></div><p class="item-desc">Klassieke buffalosaus, blauwekaasdip.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Garlic Parmesan Wings</span><span class="item-price"><span class="multi">10,50</span> <span class="multi">18,50</span> <span class="multi">26,50</span></span></div><p class="item-desc">Knoflookboter en parmezaan.</p></div>
        <div class="item"><div class="item-row"><span class="item-name">Honey Mustard Wings</span><span class="item-price"><span class="multi">10,50</span> <span class="multi">18,50</span> <span class="multi">26,50</span></span></div><p class="item-desc">Zoete honing-mosterdglaze.</p></div>
      </div>
    </div>
  </section>

  <!-- ============ COCKTAILS ============ -->
  <section class="cat" id="cocktails">
    <h2 class="cat-title">Cocktails &amp; <em>shots</em></h2>
    <p class="cat-note">Cheers! · ook 's ochtends bij het ontbijt</p>
    <div class="group">
      <h3>Cocktails</h3>
      <div class="compact">
        <div class="item"><div class="item-row"><span class="item-name">Spritz <span style="opacity:.6;font-weight:400">— Aperol, Limoncello of Watermelon</span></span><span class="item-price">12,50</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Tequila Sunrise</span><span class="item-price">11,90</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Moscow Mule</span><span class="item-price">12,50</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Cuba Libre</span><span class="item-price">12,50</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Dark &amp; Stormy</span><span class="item-price">12,50</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Mojito</span><span class="item-price">13,50</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Negroni</span><span class="item-price">14,50</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Amaretto Sour</span><span class="item-price">14,50</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Whiskey Sour</span><span class="item-price">14,50</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Margarita</span><span class="item-price">13,50</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Manhattan</span><span class="item-price">14,50</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Espresso Martini</span><span class="item-price">14,50</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Porn Star Martini</span><span class="item-price">14,50</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Long Island Ice Tea</span><span class="item-price">16,50</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Sex on the Beach</span><span class="item-price">14,50</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Orgasm</span><span class="item-price">12,50</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Cosmopolitan</span><span class="item-price">14,50</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Bloody Mary</span><span class="item-price">11,95</span></div></div>
        <div class="item"><div class="item-row"><span class="item-name">Mimosa</span><span class="item-price">8,95</span></div></div>
      </div>
