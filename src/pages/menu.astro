<script>
// Meet de hoogte van de sticky balken → exacte aansluiting, geen kier/overlap
(() => {
  const root = document.documentElement;
  const topbar = document.querySelector('.topbar');
  const catnav = document.querySelector('.cat-nav');
  const sync = () => {
    if (topbar) root.style.setProperty('--topbar-h', topbar.offsetHeight + 'px');
    if (catnav) root.style.setProperty('--catnav-h', catnav.offsetHeight + 'px');
  };
  sync();
  window.addEventListener('resize', sync);
  if (document.fonts && document.fonts.ready) document.fonts.ready.then(() => {
    sync();
    // Bij binnenkomen op een #anker: opnieuw uitlijnen nadat de hoogtes definitief zijn
    if (location.hash){
      const t = document.getElementById(location.hash.slice(1));
      if (t) t.scrollIntoView();
    }
  });
})();

// Highlight the active category chip while scrolling
(() => {
  const links = [...document.querySelectorAll('.cat-nav a')];
  const map = new Map(links.map(a => [a.getAttribute('href').slice(1), a]));
  // Tap a chip → mark it active immediately (don't wait for the scroll observer)
  links.forEach(a => a.addEventListener('click', () => {
    links.forEach(l => l.classList.remove('active'));
    a.classList.add('active');
    a.scrollIntoView({block:'nearest', inline:'center', behavior:'smooth'});
  }));
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting){
        links.forEach(l => l.classList.remove('active'));
        const link = map.get(e.target.id);
        if (link){
          link.classList.add('active');
          link.scrollIntoView({block:'nearest', inline:'center', behavior:'smooth'});
        }
      }
    });
  }, {rootMargin:'-45% 0px -50% 0px'});
  document.querySelectorAll('.cat').forEach(s => obs.observe(s));
})();
</script>
